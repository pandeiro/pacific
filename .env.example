# Environment Variables for Pacifica
#
# This is a provisional stub. Variables will be added, removed, and modified
# as development requires. DO NOT copy this file to .env and fill in real
# values - instead, copy from .env.example and let development guide what
# variables are actually needed.

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql+asyncpg://pacifica:password@localhost:5432/pacifica

# =============================================================================
# Home Location (for drive time calculations)
# =============================================================================
HOME_LAT=33.7455
HOME_LNG=-117.8676

# =============================================================================
# API Keys
# =============================================================================
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# =============================================================================
# Optional Services
# =============================================================================
# LLM service for natural language extraction (optional)
# LLM_SERVICE_URL=http://localhost:4900/v1

# Twitter/X API proxy (optional)
# TWITTER_PROXY_URL=http://localhost:8080

# Telegram webhook for alerts (optional)
# TELEGRAM_WEBHOOK_URL=http://localhost:8080/notify

# =============================================================================
# Internal Communication
# =============================================================================
# Shared secret for scraper -> API broadcast (internal Docker network only)
INTERNAL_BROADCAST_TOKEN=change_me_in_production

# =============================================================================
# Application Settings
# =============================================================================
# Logging format: "json" or "pretty"
LOG_FORMAT=pretty

# Environment: "development", "staging", or "production"
ENVIRONMENT=development
